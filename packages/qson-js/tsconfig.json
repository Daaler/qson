{
    "compilerOptions": {
        "rootDir": "./src",
        "target": "ESNext",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "esModuleInterop": true,
        "types": ["node"],

        "rewriteRelativeImportExtensions": true,
        "strictNullChecks": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "removeComments": true,
    },
    "include": ["./src/**/*"],
}
